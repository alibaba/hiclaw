{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 9000,
    "auth": {
      "token": "${HICLAW_MANAGER_GATEWAY_KEY}"
    },
    "remote": {
      "token": "${HICLAW_MANAGER_GATEWAY_KEY}"
    }
  },

  "channels": {
    "matrix": {
      "enabled": true,
      "homeserver": "${HICLAW_MATRIX_URL}",
      "accessToken": "${MANAGER_MATRIX_TOKEN}",
      "dm": {
        "policy": "allowlist",
        "allowFrom": [
          "@${HICLAW_ADMIN_USER}:${HICLAW_MATRIX_DOMAIN}"
        ]
      },
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "@${HICLAW_ADMIN_USER}:${HICLAW_MATRIX_DOMAIN}"
      ],
      "groups": {
        "*": { "allow": true, "requireMention": true }
      }
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "hiclaw-gateway": {
        "baseUrl": "${HICLAW_AI_GATEWAY_URL}/v1",
        "apiKey": "${HICLAW_MANAGER_GATEWAY_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "${HICLAW_DEFAULT_MODEL}",
            "name": "${HICLAW_DEFAULT_MODEL}",
            "reasoning": ${MODEL_REASONING},
            "contextWindow": ${MODEL_CONTEXT_WINDOW},
            "maxTokens": ${MODEL_MAX_TOKENS},
            "input": ${MODEL_INPUT}
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "timeoutSeconds": 1800,
      "workspace": "~",
      "model": {
        "primary": "hiclaw-gateway/${HICLAW_DEFAULT_MODEL}"
      },
      "maxConcurrent": 8,
      "subagents": {
        "maxConcurrent": 16
      },
      "heartbeat": {
        "every": "1h",
        "prompt": "Read ~/HEARTBEAT.md and follow the checklist. Scan ~/hiclaw-fs/shared/tasks/*/meta.json to find tasks with status=assigned. For each, read assigned_to and room_id, then ask the Worker for progress in their Room. If a Worker confirms completion, update meta.json to status=completed with completed_at. Assess capacity vs pending tasks. Reply HEARTBEAT_OK if nothing needs attention."
      }
    }
  },

  "session": {
    "dmScope": "per-channel-peer",
    "resetByType": {
      "dm":    { "mode": "daily", "atHour": 4 },
      "group": { "mode": "idle",  "idleMinutes": 2880 }
    }
  },

  "hooks": {
    "enabled": true,
    "token": "${HICLAW_MANAGER_GATEWAY_KEY}"
  },

  "plugins": {
    "load": {
      "paths": ["/opt/openclaw/extensions/matrix"]
    },
    "entries": {
      "matrix": { "enabled": true }
    }
  }
}
